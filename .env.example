# Day 4 API credentials. Copy to .env and fill in your own keys.
# .env is git-ignored; never commit real keys.

# TomTom (https://developer.tomtom.com) -- Routing, Search, Map Display, Traffic
TOMTOM_API_KEY=your_tomtom_key_here

# OpenTopography (https://portal.opentopography.org) -- global DEM for road grade
OPENTOPO_API_KEY=your_opentopography_key_here
